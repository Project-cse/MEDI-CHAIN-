# API_BASE_URL — same as mobile/.env EXPO_PUBLIC_API_URL (phone / emulator)
# API_BASE_URL_WEB — http://localhost:5000 when using Chrome on your PC
API_BASE_URL=http://<your-pc-ip>:5000
API_BASE_URL_WEB=http://localhost:5000

# Agora (client-safe key)
AGORA_APP_ID=

# Telegram bot token (prefer backend-only usage; avoid exposing in release builds)
TELEGRAM_BOT_TOKEN=
